// Bug-Predictor — 스캐너
// 버그 유발 패턴 탐지

struct BugPattern {
    pattern_id: str
    pattern_type: str  // "null_check", "overflow", "infinite_loop" 등
    line_number: i32
    severity: str
}

fn validate_input(code: str) -> bool {
    length(code) > 0 && length(code) <= 1000000
}

fn contains(text: str, pattern: str) -> bool {
    var i: i32 = 0
    while i < length(text) - length(pattern) + 1 {
        var j: i32 = 0
        var match: bool = true
        while j < length(pattern) {
            if text[i + j] != pattern[j] {
                match = false
            }
            j = j + 1
        }
        if match {
            return true
        }
        i = i + 1
    }
    false
}

fn detect_null_check_missing(code: str) -> [BugPattern] {
    var patterns: [BugPattern] = []
    if contains(code, ".") && not contains(code, "if") {
        var p = BugPattern {
            pattern_id: "BP001",
            pattern_type: "null_check",
            line_number: 50,
            severity: "critical"
        }
        patterns = append(patterns, p)
    }
    patterns
}

fn detect_overflow_risk(code: str) -> [BugPattern] {
    var patterns: [BugPattern] = []
    if contains(code, "i32") && contains(code, "+") {
        var p = BugPattern {
            pattern_id: "BP002",
            pattern_type: "overflow",
            line_number: 75,
            severity: "high"
        }
        patterns = append(patterns, p)
    }
    patterns
}

fn scan_for_bugs(code: str) -> [BugPattern] {
    if not validate_input(code) {
        return []
    }

    var all_patterns: [BugPattern] = []
    var null_patterns: [BugPattern] = detect_null_check_missing(code)
    var overflow_patterns: [BugPattern] = detect_overflow_risk(code)

    var i: i32 = 0
    while i < length(null_patterns) {
        all_patterns = append(all_patterns, null_patterns[i])
        i = i + 1
    }
    i = 0
    while i < length(overflow_patterns) {
        all_patterns = append(all_patterns, overflow_patterns[i])
        i = i + 1
    }

    all_patterns
}

fn main() {
    println("✅ Bug-Predictor Scanner 로드 완료")
}
