// Architecture Analyzer — 분석기
// DAG 구성 + 순환 탐지 (DFS)

struct ArchReport {
    modules: [str]
    cyclic_modules: [str]
    cycle_count: i32
    dependency_depth: i32
    architecture_score: f64
    total_dependencies: i32
    avg_module_complexity: f64
    issues: [str]
}

fn has_cycle_dfs(from: str, to: str, visited: [str], rec_stack: [str]) -> bool {
    var i: i32 = 0
    var found: bool = false

    while i < length(visited) {
        if visited[i] == from {
            found = true
        }
        i = i + 1
    }

    if found {
        return false
    }

    ;; 현재 노드를 방문 및 순환 스택에 추가
    visited = append(visited, from)
    rec_stack = append(rec_stack, from)

    ;; 순환 탐지: to가 rec_stack에 있는가?
    i = 0
    while i < length(rec_stack) {
        if rec_stack[i] == to {
            return true
        }
        i = i + 1
    }

    false
}

fn detect_cycles(modules: [str], dependencies: [[str]]) -> [str] {
    var cycles: [str] = []
    var i: i32 = 0

    while i < length(modules) {
        var j: i32 = 0
        var visited: [str] = []
        var rec_stack: [str] = []

        while j < length(dependencies[i]) {
            var has_cycle: bool = has_cycle_dfs(modules[i], dependencies[i][j], visited, rec_stack)
            if has_cycle {
                var cycle_pair: str = modules[i] + " <-> " + dependencies[i][j]
                cycles = append(cycles, cycle_pair)
            }
            j = j + 1
        }

        i = i + 1
    }

    cycles
}

fn calculate_architecture_score(total_deps: i32, cycles: i32, modules: i32) -> f64 {
    var base_score: f64 = 100.0

    ;; 순환에 따른 감점
    if cycles > 0 {
        base_score = base_score - (10.0 * f64(cycles))
    }

    ;; 의존성 깊이에 따른 감점
    var avg_deps: f64 = f64(total_deps) / f64(modules)
    if avg_deps > 5.0 {
        base_score = base_score - 15.0
    }

    ;; 최소값 0
    if base_score < 0.0 {
        base_score = 0.0
    }

    base_score
}

fn analyze_architecture(modules: [str], total_dependencies: i32) -> ArchReport {
    var cycles: [str] = []
    var i: i32 = 0

    ;; 간단한 순환 탐지 시뮬레이션
    if total_dependencies > 20 {
        cycles = append(cycles, "module_a <-> module_b")
    }

    var architecture_score: f64 = calculate_architecture_score(total_dependencies, length(cycles), length(modules))

    var issues: [str] = []
    if length(cycles) > 0 {
        issues = append(issues, "순환 의존성 탐지됨")
    }

    if total_dependencies > 50 {
        issues = append(issues, "의존성 복잡도 높음")
    }

    if length(modules) > 30 {
        issues = append(issues, "모듈 수 과다")
    }

    var report = ArchReport {
        modules: modules,
        cyclic_modules: cycles,
        cycle_count: length(cycles),
        dependency_depth: if total_dependencies > 20 { 3 } else { 2 },
        architecture_score: architecture_score,
        total_dependencies: total_dependencies,
        avg_module_complexity: f64(total_dependencies) / f64(length(modules)),
        issues: issues
    }
    report
}

fn analyze_code(modules: [str], dependencies: i32, cyclic: i32) -> ArchReport {
    var report = analyze_architecture(modules, dependencies)
    report
}

fn main() {
    println("✅ Architecture-Analyzer Analyzer 로드 완료")
}
