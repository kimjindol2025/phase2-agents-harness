// SQL-Optimizer 에이전트 — SQL 분석기
// 느린 쿼리 분석 + 병목 감지

// ==================== 구조체 정의 ====================

struct SlowQuery {
    sql: str
    execution_ms: i32
    rows_scanned: i32
    lock_type: str
    table: str
}

struct QueryAnalysis {
    query: SlowQuery
    issues: [str]
    severity: str
    indexes_needed: [str]
    suggested_sql: str
    confidence: f64
}

// ==================== SlowQuery 함수 ====================

fn slow_query_new(sql: str, execution_ms: i32) -> SlowQuery {
    SlowQuery {
        sql: sql,
        execution_ms: execution_ms,
        rows_scanned: 0,
        lock_type: "no_lock",
        table: ""
    }
}

fn slow_query_set_rows(query: SlowQuery, rows: i32) -> SlowQuery {
    query.rows_scanned = rows
    query
}

fn slow_query_set_lock(query: SlowQuery, lock: str) -> SlowQuery {
    query.lock_type = lock
    query
}

fn slow_query_set_table(query: SlowQuery, table: str) -> SlowQuery {
    query.table = table
    query
}

fn slow_query_display(query: SlowQuery) -> str {
    var s: str = ""
    s = s + "SlowQuery { "
    s = s + "table=" + query.table + ", "
    s = s + "time=" + str(query.execution_ms) + "ms, "
    s = s + "rows=" + str(query.rows_scanned) + " }"
    s
}

// ✅ 입력 검증 (보안: CRITICAL 이슈 해결)
fn validate_input(query: str) -> bool {
    if length(query) == 0 { return false }
    if length(query) > 1000000 { return false }
    return true
}

// ==================== 분석 함수 ====================

fn analyze_query(q: SlowQuery) -> QueryAnalysis {
    if !validate_input(q.sql) {
        var empty_analysis = QueryAnalysis {
            query: q,
            issues: [],
            severity: "invalid",
            indexes_needed: [],
            suggested_sql: "",
            confidence: 0.0
        }
        return empty_analysis
    }

    var analysis = QueryAnalysis {
        query: q,
        issues: [],
        severity: "low",
        indexes_needed: [],
        suggested_sql: q.sql,
        confidence: 0.0
    }

    ;; 규칙 1: 실행 시간 > 1000ms → high severity
    if q.execution_ms > 1000 {
        analysis.issues.push("Execution time exceeds 1000ms")
        analysis.severity = "high"
    }

    ;; 규칙 2: 스캔한 행 > 100,000 → missing index 의심
    if q.rows_scanned > 100000 {
        analysis.issues.push("Large table scan detected")
        analysis.indexes_needed.push("index_on_" + q.table + "_id")
        if analysis.severity != "high" {
            analysis.severity = "medium"
        }
    }

    ;; 규칙 3: 잠금 타입 = deadlock → critical
    if q.lock_type == "deadlock" {
        analysis.issues.push("Deadlock detected")
        analysis.severity = "critical"
    }

    ;; 규칙 4: WHERE 절 미포함 → full table scan
    if detect_full_scan(q.sql) {
        analysis.issues.push("Full table scan - add WHERE clause or index")
        if length(analysis.indexes_needed) == 0 {
            analysis.indexes_needed.push("index_on_" + q.table + "_filter_column")
        }
    }

    ;; 규칙 5: JOIN 다중 → join optimization 필요
    if detect_multiple_joins(q.sql) {
        analysis.issues.push("Multiple JOINs detected - consider optimization")
        if analysis.severity == "low" {
            analysis.severity = "medium"
        }
    }

    ;; 신뢰도 계산 (최대 1.0)
    var raw_confidence = 0.7 + f64(length(analysis.indexes_needed)) * 0.1
    if raw_confidence > 1.0 {
        analysis.confidence = 1.0
    } else {
        analysis.confidence = raw_confidence
    }

    analysis
}

fn detect_missing_index(sql: str) -> [str] {
    var indexes: [str] = []

    ;; 단순 휴리스틱: WHERE 키워드 포함하면 인덱스 필요
    if index_of(sql, "WHERE") >= 0 {
        indexes.push("index_on_where_column")
    }

    ;; ORDER BY 포함하면 정렬 인덱스 필요
    if index_of(sql, "ORDER BY") >= 0 {
        indexes.push("index_on_order_column")
    }

    ;; GROUP BY 포함하면 그룹 인덱스 필요
    if index_of(sql, "GROUP BY") >= 0 {
        indexes.push("index_on_group_column")
    }

    indexes
}

fn detect_full_scan(sql: str) -> bool {
    ;; WHERE 절 없으면 full scan 가능성 높음
    if index_of(sql, "WHERE") < 0 {
        return true
    }
    false
}

fn detect_multiple_joins(sql: str) -> bool {
    ;; JOIN 키워드가 2개 이상이면 multiple join
    var join_count: i32 = 0
    var pos: i32 = 0

    while pos < length(sql) {
        pos = index_of_from(sql, "JOIN", pos)
        if pos < 0 {
            break
        }
        join_count = join_count + 1
        pos = pos + 4
    }

    join_count > 1
}

;; 문자열 검색 헬퍼
fn index_of(text: str, pattern: str) -> i32 {
    var i: i32 = 0
    while i < length(text) - length(pattern) + 1 {
        if substring(text, i, i + length(pattern)) == pattern {
            return i
        }
        i = i + 1
    }
    -1
}

fn index_of_from(text: str, pattern: str, start: i32) -> i32 {
    var i: i32 = start
    while i < length(text) - length(pattern) + 1 {
        if substring(text, i, i + length(pattern)) == pattern {
            return i
        }
        i = i + 1
    }
    -1
}

fn suggest_indexes(analysis: QueryAnalysis) -> [str] {
    analysis.indexes_needed
}

// ==================== 배치 분석 ====================

fn batch_analyze(queries: [SlowQuery]) -> [QueryAnalysis] {
    var results: [QueryAnalysis] = []
    var i: i32 = 0

    while i < length(queries) {
        var analysis = analyze_query(queries[i])
        results.push(analysis)
        i = i + 1
    }

    results
}

// ==================== 분석 리포트 ====================

fn analysis_display(analysis: QueryAnalysis) -> str {
    var s: str = ""
    s = s + "QueryAnalysis { "
    s = s + "severity=" + analysis.severity + ", "
    s = s + "issues=" + str(length(analysis.issues)) + ", "
    s = s + "indexes=" + str(length(analysis.indexes_needed)) + ", "
    s = s + "confidence=" + str(analysis.confidence * 100.0) + "% }"
    s
}

fn analysis_report(analyses: [QueryAnalysis]) -> str {
    var s: str = ""
    s = s + "# SQL Analysis Report\n\n"
    s = s + "## Summary\n"
    s = s + "- Total queries: " + str(length(analyses)) + "\n"

    var critical_count: i32 = 0
    var high_count: i32 = 0
    var medium_count: i32 = 0

    var i: i32 = 0
    while i < length(analyses) {
        if analyses[i].severity == "critical" {
            critical_count = critical_count + 1
        } else if analyses[i].severity == "high" {
            high_count = high_count + 1
        } else if analyses[i].severity == "medium" {
            medium_count = medium_count + 1
        }
        i = i + 1
    }

    s = s + "- Critical: " + str(critical_count) + "\n"
    s = s + "- High: " + str(high_count) + "\n"
    s = s + "- Medium: " + str(medium_count) + "\n\n"

    s = s + "## Detailed Analysis\n"
    i = 0
    while i < length(analyses) {
        s = s + "### Query " + str(i + 1) + "\n"
        s = s + "- Severity: " + analyses[i].severity + "\n"
        s = s + "- Issues: " + str(length(analyses[i].issues)) + "\n"
        s = s + "- Indexes needed: " + str(length(analyses[i].indexes_needed)) + "\n"
        i = i + 1
    }

    s
}

// ==================== 테스트 ====================

fn main() {
    println("╔═══════════════════════════════════════════╗")
    println("║       SQL-Optimizer — SQL 분석기          ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    ;; 느린 쿼리 생성
    println("1️⃣ 느린 쿼리 생성")
    var q1 = slow_query_new("SELECT * FROM users", 1500)
    q1 = slow_query_set_rows(q1, 150000)
    q1 = slow_query_set_table(q1, "users")
    println(slow_query_display(q1))
    println("")

    var q2 = slow_query_new("SELECT * FROM orders WHERE status = 'pending'", 2500)
    q2 = slow_query_set_rows(q2, 500000)
    q2 = slow_query_set_lock(q2, "deadlock")
    q2 = slow_query_set_table(q2, "orders")
    println(slow_query_display(q2))
    println("")

    ;; 쿼리 분석
    println("2️⃣ 쿼리 분석")
    var analysis1 = analyze_query(q1)
    println(analysis_display(analysis1))
    println("문제점:")
    var i: i32 = 0
    while i < length(analysis1.issues) {
        println("  - " + analysis1.issues[i])
        i = i + 1
    }
    println("")

    var analysis2 = analyze_query(q2)
    println(analysis_display(analysis2))
    println("")

    ;; 인덱스 제안
    println("3️⃣ 인덱스 제안")
    var indexes1 = suggest_indexes(analysis1)
    println("Query 1 인덱스:")
    i = 0
    while i < length(indexes1) {
        println("  - " + indexes1[i])
        i = i + 1
    }
    println("")

    ;; 배치 분석
    println("4️⃣ 배치 분석")
    var queries: [SlowQuery] = [q1, q2]
    var analyses = batch_analyze(queries)
    println("분석 완료: " + str(length(analyses)) + "개 쿼리")
    println("")

    ;; 리포트 생성
    println("5️⃣ 분석 리포트")
    var report = analysis_report(analyses)
    println(substring(report, 0, 200) + "...")
    println("")

    println("✅ SQL 분석기 로드 완료")
}
