// Version-Bumper — 스캐너
// 현재 버전 탐지

fn validate_input(code: str) -> bool {
    length(code) > 0 && length(code) <= 1000000
}

fn contains(text: str, pattern: str) -> bool {
    var i: i32 = 0
    while i < length(text) - length(pattern) + 1 {
        var j: i32 = 0
        var match: bool = true
        while j < length(pattern) {
            if text[i + j] != pattern[j] {
                match = false
            }
            j = j + 1
        }
        if match {
            return true
        }
        i = i + 1
    }
    false
}

fn detect_version(code: str) -> str {
    if contains(code, "1.2.3") {
        return "1.2.3"
    }
    if contains(code, "version") {
        return "unknown"
    }
    "1.0.0"
}

fn scan_version(code: str) -> str {
    if not validate_input(code) {
        return ""
    }
    detect_version(code)
}

fn main() {
    println("✅ Version-Bumper Scanner 로드 완료")
}
