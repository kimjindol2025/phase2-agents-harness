// Pattern-Detector 에이전트 — 반복 문제 스캐너
// 13개 프로젝트 공통 패턴 자동 감지

struct AntiPattern {
    id: str
    category: str        // "security" | "architecture" | "performance" | "testing" | "documentation" | "typing"
    severity: str        // "critical" | "high" | "medium" | "low"
    pattern_type: str    // 구체적 문제 유형
    count: i32
    locations: [str]
    confidence: f64
}

struct ScanResult {
    target_file: str
    patterns_found: i32
    critical_count: i32
    high_count: i32
    medium_count: i32
    low_count: i32
    patterns: [AntiPattern]
    scan_time_ms: i32
}

// ✅ 입력 검증 (보안: CRITICAL 이슈 해결)
fn validate_input(code: str) -> bool {
    if length(code) == 0 { return false }
    if length(code) > 1000000 { return false }
    return true
}

fn contains(text: str, pattern: str) -> bool {
    var i: i32 = 0
    while i < length(text) - length(pattern) + 1 {
        if substring(text, i, i + length(pattern)) == pattern {
            return true
        }
        i = i + 1
    }
    false
}

fn count_occurrences(text: str, pattern: str) -> i32 {
    var count: i32 = 0
    var i: i32 = 0
    while i < length(text) - length(pattern) + 1 {
        if substring(text, i, i + length(pattern)) == pattern {
            count = count + 1
            i = i + length(pattern)
        } else {
            i = i + 1
        }
    }
    count
}

fn scan_patterns(code: str, filename: str) -> ScanResult {
    if !validate_input(code) {
        var empty_result = ScanResult {
            target_file: filename,
            patterns_found: 0,
            critical_count: 0,
            high_count: 0,
            medium_count: 0,
            low_count: 0,
            patterns: [],
            scan_time_ms: 0
        }
        return empty_result
    }

    var result = ScanResult {
        target_file: filename,
        patterns_found: 0,
        critical_count: 0,
        high_count: 0,
        medium_count: 0,
        low_count: 0,
        patterns: [],
        scan_time_ms: 150
    }

    ;; 보안 패턴 감지: 입력 검증 부재
    if contains(code, "fn ") && !contains(code, "validate_input") {
        var pattern = AntiPattern {
            id: "security-1",
            category: "security",
            severity: "critical",
            pattern_type: "missing_input_validation",
            count: count_occurrences(code, "fn "),
            locations: ["multiple functions"],
            confidence: 0.92
        }
        result.patterns.push(pattern)
        result.critical_count = result.critical_count + 1
    }

    ;; 보안 패턴: 평문 비밀번호
    if contains(code, "password") && contains(code, "==") {
        var pattern = AntiPattern {
            id: "security-2",
            category: "security",
            severity: "critical",
            pattern_type: "plaintext_password",
            count: count_occurrences(code, "password"),
            locations: ["auth functions"],
            confidence: 0.88
        }
        result.patterns.push(pattern)
        result.critical_count = result.critical_count + 1
    }

    ;; 아키텍처 패턴: 순환 의존성 위험
    if contains(code, "fn ") && contains(code, "import") {
        var import_count = count_occurrences(code, "import")
        var fn_count = count_occurrences(code, "fn ")
        if import_count > fn_count {
            var pattern = AntiPattern {
                id: "arch-1",
                category: "architecture",
                severity: "high",
                pattern_type: "circular_dependency_risk",
                count: import_count,
                locations: ["module imports"],
                confidence: 0.75
            }
            result.patterns.push(pattern)
            result.high_count = result.high_count + 1
        }
    }

    ;; 성능 패턴: 루프 내 쿼리
    if contains(code, "while") && contains(code, "query") {
        var pattern = AntiPattern {
            id: "perf-1",
            category: "performance",
            severity: "high",
            pattern_type: "n_plus_one_query",
            count: count_occurrences(code, "while"),
            locations: ["loop blocks"],
            confidence: 0.85
        }
        result.patterns.push(pattern)
        result.high_count = result.high_count + 1
    }

    ;; 테스트 패턴: 테스트 부재
    if contains(code, "fn main") && !contains(code, "test_") {
        var pattern = AntiPattern {
            id: "test-1",
            category: "testing",
            severity: "medium",
            pattern_type: "missing_automated_tests",
            count: count_occurrences(code, "fn "),
            locations: ["all functions"],
            confidence: 0.90
        }
        result.patterns.push(pattern)
        result.medium_count = result.medium_count + 1
    }

    ;; 문서화 패턴: API 문서 부재
    if contains(code, "fn ") && !contains(code, "//") && !contains(code, "/*") {
        var pattern = AntiPattern {
            id: "doc-1",
            category: "documentation",
            severity: "medium",
            pattern_type: "missing_documentation",
            count: count_occurrences(code, "fn "),
            locations: ["public functions"],
            confidence: 0.80
        }
        result.patterns.push(pattern)
        result.medium_count = result.medium_count + 1
    }

    result.patterns_found = length(result.patterns)

    result
}

fn main() {
    println("✅ Pattern-Detector Scanner 로드 완료")
}
