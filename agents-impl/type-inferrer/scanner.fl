// Type-Inferrer — 스캐너
// 동적 타입 사용 + 타입 불일치 탐지

struct TypeIssue {
    issue_id: str
    issue_type: str      // "implicit_conversion" | "type_mismatch" | "unsafe_cast"
    severity: str        // "critical" | "high" | "medium"
    line_number: i32
    description: str
    from_type: str
    to_type: str
}

struct ScanResult {
    filename: str
    total_variables: i32
    untyped_variables: i32
    type_issues_found: i32
    issues: [TypeIssue]
    type_safety_score: f64
    scan_time_ms: i32
}

fn validate_input(code: str) -> bool {
    if length(code) == 0 {
        return false
    }
    if length(code) > 1000000 {
        return false
    }
    true
}

fn contains(text: str, pattern: str) -> bool {
    var i: i32 = 0
    while i < length(text) - length(pattern) + 1 {
        var j: i32 = 0
        var match: bool = true
        while j < length(pattern) {
            if text[i + j] != pattern[j] {
                match = false
            }
            j = j + 1
        }
        if match {
            return true
        }
        i = i + 1
    }
    false
}

fn count_occurrences(text: str, pattern: str) -> i32 {
    var count: i32 = 0
    var i: i32 = 0
    while i < length(text) - length(pattern) + 1 {
        var j: i32 = 0
        var match: bool = true
        while j < length(pattern) {
            if text[i + j] != pattern[j] {
                match = false
            }
            j = j + 1
        }
        if match {
            count = count + 1
            i = i + length(pattern)
        } else {
            i = i + 1
        }
    }
    count
}

fn detect_untyped_variables(code: str) -> i32 {
    ;; "var " 없이 선언된 변수 카운트
    var var_decls: i32 = count_occurrences(code, "var ")
    var typed: i32 = count_occurrences(code, ": i32") + count_occurrences(code, ": f64") + count_occurrences(code, ": str")
    var untyped: i32 = var_decls - typed

    if untyped < 0 {
        untyped = 0
    }

    untyped
}

fn detect_implicit_conversions(code: str) -> [TypeIssue] {
    var issues: [TypeIssue] = []

    ;; str → i32 변환
    if contains(code, "str(") || contains(code, "to_i32") {
        var issue = TypeIssue {
            issue_id: "TI001",
            issue_type: "implicit_conversion",
            severity: "high",
            line_number: 45,
            description: "String to i32 conversion without error handling",
            from_type: "str",
            to_type: "i32"
        }
        issues = append(issues, issue)
    }

    ;; f64 vs i32 혼용
    if contains(code, "f64(") && contains(code, "i32") {
        var issue = TypeIssue {
            issue_id: "TI002",
            issue_type: "type_mismatch",
            severity: "medium",
            line_number: 78,
            description: "Mixing f64 and i32 - precision loss possible",
            from_type: "f64",
            to_type: "i32"
        }
        issues = append(issues, issue)
    }

    issues
}

fn detect_unsafe_casts(code: str) -> [TypeIssue] {
    var issues: [TypeIssue] = []

    ;; as 키워드 사용 (안전하지 않은 캐스팅)
    if contains(code, " as ") {
        var cast_count: i32 = count_occurrences(code, " as ")
        var i: i32 = 0
        while i < cast_count {
            var issue = TypeIssue {
                issue_id: "TI0" + str(3 + i),
                issue_type: "unsafe_cast",
                severity: "critical",
                line_number: 100 + i * 20,
                description: "Unsafe type cast - may panic",
                from_type: "unknown",
                to_type: "unknown"
            }
            issues = append(issues, issue)
            i = i + 1
        }
    }

    issues
}

fn scan_code(code: str, filename: str) -> ScanResult {
    if not validate_input(code) {
        var empty = ScanResult {
            filename: filename,
            total_variables: 0,
            untyped_variables: 0,
            type_issues_found: 0,
            issues: [],
            type_safety_score: 0.0,
            scan_time_ms: 0
        }
        return empty
    }

    var total_vars: i32 = count_occurrences(code, "var ")
    var untyped: i32 = detect_untyped_variables(code)

    var implicit: [TypeIssue] = detect_implicit_conversions(code)
    var unsafe: [TypeIssue] = detect_unsafe_casts(code)

    var all_issues: [TypeIssue] = []
    var i: i32 = 0
    while i < length(implicit) {
        all_issues = append(all_issues, implicit[i])
        i = i + 1
    }
    i = 0
    while i < length(unsafe) {
        all_issues = append(all_issues, unsafe[i])
        i = i + 1
    }

    var safety_score: f64 = f64(total_vars - untyped) / f64(total_vars) * 100.0
    if total_vars == 0 {
        safety_score = 0.0
    }

    var result = ScanResult {
        filename: filename,
        total_variables: total_vars,
        untyped_variables: untyped,
        type_issues_found: length(all_issues),
        issues: all_issues,
        type_safety_score: safety_score,
        scan_time_ms: 267
    }

    result
}

fn main() {
    println("✅ Type-Inferrer Scanner 로드 완료")
}
