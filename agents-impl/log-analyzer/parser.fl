// Log-Analyzer 에이전트 — 로그 파서
// 로그 엔트리 파싱 및 구조화

// ==================== 구조체 정의 ====================

struct LogEntry {
    timestamp: str
    level: str
    message: str
    source: str
    line_number: i32
    raw_text: str
}

struct ParseResult {
    filename: str
    total_lines: i32
    parsed_entries: i32
    error_count: i32
    warning_count: i32
    info_count: i32
    debug_count: i32
    entries: [LogEntry]
    parse_time_ms: i32
}

// ==================== 헬퍼 함수 ====================

fn index_of(text: str, pattern: str) -> i32 {
    var i: i32 = 0
    while i < length(text) - length(pattern) + 1 {
        if substring(text, i, i + length(pattern)) == pattern {
            return i
        }
        i = i + 1
    }
    -1
}

fn contains(text: str, pattern: str) -> bool {
    index_of(text, pattern) >= 0
}

fn trim_left(text: str) -> str {
    var i: i32 = 0
    while i < length(text) {
        var c = substring(text, i, i + 1)
        if c == " " || c == "\t" {
            i = i + 1
        } else {
            break
        }
    }
    substring(text, i, length(text))
}

// ==================== 로그 파싱 함수 ====================

fn parse_log_line(line: str, line_num: i32) -> LogEntry {
    var entry = LogEntry {
        timestamp: "",
        level: "INFO",
        message: line,
        source: "unknown",
        line_number: line_num,
        raw_text: line
    }

    ;; 타임스탬프 추출 (ISO 8601 형식)
    if contains(line, "T") && contains(line, "Z") {
        var t_pos = index_of(line, "T")
        var z_pos = index_of(line, "Z")
        if t_pos > 0 && z_pos > t_pos {
            entry.timestamp = substring(line, t_pos - 10, z_pos + 1)
        }
    }

    ;; 레벨 추출
    if contains(line, "[ERROR]") || contains(line, "ERROR:") {
        entry.level = "ERROR"
    } else if contains(line, "[WARN]") || contains(line, "WARNING:") {
        entry.level = "WARN"
    } else if contains(line, "[INFO]") || contains(line, "INFO:") {
        entry.level = "INFO"
    } else if contains(line, "[DEBUG]") || contains(line, "DEBUG:") {
        entry.level = "DEBUG"
    }

    ;; 소스 추출 (파일명 패턴)
    var start_idx = index_of(line, "at ")
    if start_idx >= 0 {
        var end_idx = index_of(substring(line, start_idx + 3, length(line)), ":")
        if end_idx > 0 {
            entry.source = substring(line, start_idx + 3, start_idx + 3 + end_idx)
        }
    }

    ;; 메시지 정리
    var trimmed = trim_left(line)
    if length(trimmed) > 100 {
        entry.message = substring(trimmed, 0, 100)
    } else {
        entry.message = trimmed
    }

    entry
}

fn parse_logs(log_content: str, filename: str) -> ParseResult {
    var result = ParseResult {
        filename: filename,
        total_lines: 0,
        parsed_entries: 0,
        error_count: 0,
        warning_count: 0,
        info_count: 0,
        debug_count: 0,
        entries: [],
        parse_time_ms: 150
    }

    ;; 라인 수 계산
    var line_count: i32 = 1
    var i: i32 = 0
    while i < length(log_content) {
        if substring(log_content, i, i + 1) == "\n" {
            line_count = line_count + 1
        }
        i = i + 1
    }
    result.total_lines = line_count

    ;; 라인별 파싱
    var current_line: str = ""
    var current_line_num: i32 = 1
    i = 0
    while i < length(log_content) {
        var char = substring(log_content, i, i + 1)

        if char == "\n" {
            if length(current_line) > 0 {
                var entry = parse_log_line(current_line, current_line_num)
                result.entries.push(entry)
                result.parsed_entries = result.parsed_entries + 1

                ;; 레벨 카운트
                if entry.level == "ERROR" {
                    result.error_count = result.error_count + 1
                } else if entry.level == "WARN" {
                    result.warning_count = result.warning_count + 1
                } else if entry.level == "INFO" {
                    result.info_count = result.info_count + 1
                } else if entry.level == "DEBUG" {
                    result.debug_count = result.debug_count + 1
                }
            }
            current_line = ""
            current_line_num = current_line_num + 1
        } else {
            current_line = current_line + char
        }

        i = i + 1
    }

    ;; 마지막 라인 처리
    if length(current_line) > 0 {
        var entry = parse_log_line(current_line, current_line_num)
        result.entries.push(entry)
        result.parsed_entries = result.parsed_entries + 1

        if entry.level == "ERROR" {
            result.error_count = result.error_count + 1
        } else if entry.level == "WARN" {
            result.warning_count = result.warning_count + 1
        } else if entry.level == "INFO" {
            result.info_count = result.info_count + 1
        } else if entry.level == "DEBUG" {
            result.debug_count = result.debug_count + 1
        }
    }

    result
}

fn batch_parse(filenames: [str], logs: [str]) -> [ParseResult] {
    var results: [ParseResult] = []
    var i: i32 = 0

    while i < length(filenames) {
        var result = parse_logs(logs[i], filenames[i])
        results.push(result)
        i = i + 1
    }

    results
}

// ==================== 리포트 생성 ====================

fn parse_report(results: [ParseResult]) -> str {
    var report: str = ""
    report = report + "# Log Parse Report\n\n"
    report = report + "## Summary\n"
    report = report + "- Files parsed: " + str(length(results)) + "\n"

    var total_lines: i32 = 0
    var total_entries: i32 = 0
    var total_errors: i32 = 0
    var total_warnings: i32 = 0

    var i: i32 = 0
    while i < length(results) {
        total_lines = total_lines + results[i].total_lines
        total_entries = total_entries + results[i].parsed_entries
        total_errors = total_errors + results[i].error_count
        total_warnings = total_warnings + results[i].warning_count
        i = i + 1
    }

    report = report + "- Total lines: " + str(total_lines) + "\n"
    report = report + "- Parsed entries: " + str(total_entries) + "\n"
    report = report + "- Errors: " + str(total_errors) + "\n"
    report = report + "- Warnings: " + str(total_warnings) + "\n\n"

    report = report + "## Files\n"
    i = 0
    while i < length(results) {
        report = report + "### " + results[i].filename + "\n"
        report = report + "- Lines: " + str(results[i].total_lines) + "\n"
        report = report + "- Entries: " + str(results[i].parsed_entries) + "\n"
        report = report + "- Errors: " + str(results[i].error_count) + "\n"
        report = report + "- Warnings: " + str(results[i].warning_count) + "\n\n"
        i = i + 1
    }

    report
}

// ==================== 테스트 ====================

fn main() {
    println("╔═══════════════════════════════════════════╗")
    println("║     Log-Analyzer — 로그 파서            ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    ;; 1. 로그 파싱
    println("1️⃣ 로그 파싱")
    var test_log = "2026-04-04T10:30:00Z [ERROR] Database connection failed at connection.py:45\n2026-04-04T10:30:01Z [WARN] Retry attempt 1\n2026-04-04T10:30:02Z [INFO] Service started"
    var result = parse_logs(test_log, "app.log")
    println("파일: " + result.filename)
    println("라인: " + str(result.total_lines))
    println("엔트리: " + str(result.parsed_entries))
    println("에러: " + str(result.error_count))
    println("경고: " + str(result.warning_count))
    println("")

    ;; 2. 레벨별 통계
    println("2️⃣ 레벨별 통계")
    println("- ERROR: " + str(result.error_count))
    println("- WARN: " + str(result.warning_count))
    println("- INFO: " + str(result.info_count))
    println("- DEBUG: " + str(result.debug_count))
    println("")

    ;; 3. 엔트리 상세
    println("3️⃣ 파싱된 엔트리")
    var i: i32 = 0
    while i < length(result.entries) {
        var entry = result.entries[i]
        println("  [" + entry.level + "] " + entry.message)
        i = i + 1
    }
    println("")

    ;; 4. 배치 파싱
    println("4️⃣ 배치 파싱")
    var filenames: [str] = ["app.log", "system.log"]
    var logs: [str] = [test_log, test_log]
    var batch_results = batch_parse(filenames, logs)
    println("파싱 완료: " + str(length(batch_results)) + "개 파일")
    println("")

    ;; 5. 리포트
    println("5️⃣ 파싱 리포트")
    var report = parse_report(batch_results)
    println(substring(report, 0, 250) + "...")
    println("")

    println("✅ 로그 파서 로드 완료")
}
