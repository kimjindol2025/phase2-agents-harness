// Pipeline-Builder — 스캐너
// 프로젝트 구조 분석

struct ProjectStructure {
    has_tests: bool
    has_build_script: bool
    has_ci_config: bool
    main_files: [str]
    test_files: [str]
    languages_detected: [str]
}

fn validate_input(code: str) -> bool {
    length(code) > 0 && length(code) <= 1000000
}

fn contains(text: str, pattern: str) -> bool {
    var i: i32 = 0
    while i < length(text) - length(pattern) + 1 {
        var j: i32 = 0
        var match: bool = true
        while j < length(pattern) {
            if text[i + j] != pattern[j] {
                match = false
            }
            j = j + 1
        }
        if match {
            return true
        }
        i = i + 1
    }
    false
}

fn detect_structure(code: str) -> ProjectStructure {
    var structure = ProjectStructure {
        has_tests: contains(code, "test") || contains(code, "fn test_"),
        has_build_script: contains(code, "build") || contains(code, "Makefile"),
        has_ci_config: contains(code, "ci") || contains(code, "workflow"),
        main_files: ["main.fl"],
        test_files: if contains(code, "test") { ["test.fl"] } else { [] },
        languages_detected: ["freelang"]
    }
    structure
}

fn scan_project(code: str, filename: str) -> ProjectStructure {
    if not validate_input(code) {
        return ProjectStructure {
            has_tests: false,
            has_build_script: false,
            has_ci_config: false,
            main_files: [],
            test_files: [],
            languages_detected: []
        }
    }
    detect_structure(code)
}

fn main() {
    println("✅ Pipeline-Builder Scanner 로드 완료")
}
