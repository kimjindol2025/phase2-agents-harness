// Phase 2 에이전트 하네스 — 오케스트레이터
// 에이전트 실행 엔진 + 레지스트리

// ==================== 구조체 정의 ====================

struct AgentConfig {
    name: str
    role: str
    tools: [str]
    model: str
    max_iterations: i32
    timeout_ms: i32
}

struct AgentRun {
    agent: str
    input: str
    output: str
    status: str
    iterations: i32
    elapsed_ms: i32
    cost_usd: f64
    error: str
}

struct HarnessResult {
    total_runs: i32
    succeeded: i32
    failed: i32
    total_cost: f64
    total_elapsed: i32
    runs: [AgentRun]
}

struct AgentRegistry {
    agents: [AgentConfig]
    size: i32
}

// ==================== AgentConfig 함수 ====================

fn agent_config_new(name: str, role: str, model: str) -> AgentConfig {
    AgentConfig {
        name: name,
        role: role,
        tools: [],
        model: model,
        max_iterations: 10,
        timeout_ms: 30000
    }
}

fn agent_config_add_tool(config: AgentConfig, tool: str) -> AgentConfig {
    config.tools.push(tool)
    config
}

fn agent_config_add_tools(config: AgentConfig, tools: [str]) -> AgentConfig {
    var i: i32 = 0
    while i < length(tools) {
        config.tools.push(tools[i])
        i = i + 1
    }
    config
}

fn agent_config_set_iterations(config: AgentConfig, max_iter: i32) -> AgentConfig {
    config.max_iterations = max_iter
    config
}

fn agent_config_set_timeout(config: AgentConfig, timeout_ms: i32) -> AgentConfig {
    config.timeout_ms = timeout_ms
    config
}

fn agent_config_display(config: AgentConfig) -> str {
    var s: str = ""
    s = s + "AgentConfig { "
    s = s + "name=" + config.name + ", "
    s = s + "role=" + config.role + ", "
    s = s + "model=" + config.model + ", "
    s = s + "tools=" + str(length(config.tools)) + ", "
    s = s + "timeout=" + str(config.timeout_ms) + "ms }"
    s
}

// ==================== AgentRun 함수 ====================

fn agent_run_new(agent: str) -> AgentRun {
    AgentRun {
        agent: agent,
        input: "",
        output: "",
        status: "pending",
        iterations: 0,
        elapsed_ms: 0,
        cost_usd: 0.0,
        error: ""
    }
}

fn agent_run_success(run: AgentRun, output: str, iterations: i32, elapsed: i32, cost: f64) -> AgentRun {
    run.output = output
    run.status = "success"
    run.iterations = iterations
    run.elapsed_ms = elapsed
    run.cost_usd = cost
    run
}

fn agent_run_failed(run: AgentRun, error: str, iterations: i32, elapsed: i32) -> AgentRun {
    run.status = "failed"
    run.error = error
    run.iterations = iterations
    run.elapsed_ms = elapsed
    run
}

fn agent_run_timeout(run: AgentRun, max_iterations: i32) -> AgentRun {
    run.status = "timeout"
    run.error = "Exceeded timeout after " + str(max_iterations) + " iterations"
    run.iterations = max_iterations
    run
}

fn agent_run_display(run: AgentRun) -> str {
    var s: str = ""
    s = s + "AgentRun[" + run.agent + "] "
    s = s + "status=" + run.status + " "
    s = s + "iter=" + str(run.iterations) + " "
    s = s + "ms=" + str(run.elapsed_ms) + " "
    s = s + "cost=$" + str(run.cost_usd)
    s
}

// ==================== Harness 실행 ====================

fn harness_run(config: AgentConfig, input: str) -> AgentRun {
    var run = agent_run_new(config.name)
    run.input = input

    ;; 실제 실행 (흉내)
    var output = "[AGENT " + config.name + "] Processed: " + substring(input, 0, 50) + "..."
    var iterations: i32 = 1
    var elapsed: i32 = 100
    var cost: f64 = 0.005

    run = agent_run_success(run, output, iterations, elapsed, cost)
    run
}

fn harness_run_batch(configs: [AgentConfig], inputs: [str]) -> HarnessResult {
    var result = HarnessResult {
        total_runs: length(configs) * length(inputs),
        succeeded: 0,
        failed: 0,
        total_cost: 0.0,
        total_elapsed: 0,
        runs: []
    }

    ;; 배열 검증
    if length(configs) == 0 || length(inputs) == 0 {
        result.total_runs = 0
        return result
    }

    var i: i32 = 0
    while i < length(configs) {
        var j: i32 = 0
        while j < length(inputs) {
            var run = harness_run(configs[i], inputs[j])
            result.runs.push(run)

            if run.status == "success" {
                result.succeeded = result.succeeded + 1
            } else if run.status == "timeout" || run.status == "failed" {
                result.failed = result.failed + 1
            }

            result.total_cost = result.total_cost + run.cost_usd
            result.total_elapsed = result.total_elapsed + run.elapsed_ms

            j = j + 1
        }
        i = i + 1
    }

    result
}

fn harness_result_display(result: HarnessResult) -> str {
    var s: str = ""
    s = s + "HarnessResult { "
    s = s + "total=" + str(result.total_runs) + ", "
    s = s + "success=" + str(result.succeeded) + ", "
    s = s + "failed=" + str(result.failed) + ", "
    s = s + "cost=$" + str(result.total_cost) + ", "
    s = s + "elapsed=" + str(result.total_elapsed) + "ms }"
    s
}

// ==================== 에이전트 레지스트리 ====================

fn agent_registry_new() -> AgentRegistry {
    AgentRegistry {
        agents: [],
        size: 0
    }
}

fn registry_add(registry: AgentRegistry, config: AgentConfig) -> AgentRegistry {
    registry.agents.push(config)
    registry.size = registry.size + 1
    registry
}

fn registry_get(registry: AgentRegistry, name: str) -> AgentConfig {
    var i: i32 = 0
    var found: AgentConfig = agent_config_new("", "", "")

    while i < length(registry.agents) {
        if registry.agents[i].name == name {
            found = registry.agents[i]
        }
        i = i + 1
    }

    found
}

fn registry_list(registry: AgentRegistry) -> [str] {
    var names: [str] = []
    var i: i32 = 0

    while i < length(registry.agents) {
        names.push(registry.agents[i].name)
        i = i + 1
    }

    names
}

fn registry_size(registry: AgentRegistry) -> i32 {
    registry.size
}

fn registry_display(registry: AgentRegistry) -> str {
    var s: str = ""
    s = s + "AgentRegistry { agents=" + str(registry.size) + " }"
    s
}

// ==================== 성과 증명 생성 ====================

fn proof_output(run: AgentRun) -> str {
    var s: str = ""
    s = s + "# OUTPUT_PROOF: " + run.agent + "\n\n"
    s = s + "## 실행 결과\n"
    s = s + "- 상태: " + run.status + "\n"
    s = s + "- 반복: " + str(run.iterations) + "\n"
    s = s + "- 소요 시간: " + str(run.elapsed_ms) + "ms\n"
    s = s + "- 비용: $" + str(run.cost_usd) + "\n\n"

    if run.status == "success" {
        s = s + "## 출력\n```\n" + run.output + "\n```\n"
    } else {
        s = s + "## 에러\n```\n" + run.error + "\n```\n"
    }

    s
}

fn proof_batch_output(result: HarnessResult) -> str {
    var s: str = ""
    s = s + "# OUTPUT_PROOF — Batch Results\n\n"
    s = s + "## 종합 결과\n"
    s = s + "| 항목 | 값 |\n"
    s = s + "|------|-----|\n"
    s = s + "| 총 실행 | " + str(result.total_runs) + " |\n"
    s = s + "| 성공 | " + str(result.succeeded) + " |\n"
    s = s + "| 실패 | " + str(result.failed) + " |\n"
    s = s + "| 총 비용 | $" + str(result.total_cost) + " |\n"
    s = s + "| 총 시간 | " + str(result.total_elapsed) + "ms |\n\n"

    s = s + "## 개별 결과\n"
    var i: i32 = 0
    while i < length(result.runs) {
        s = s + "- " + agent_run_display(result.runs[i]) + "\n"
        i = i + 1
    }

    s
}

// ==================== 테스트 ====================

fn main() {
    println("╔═══════════════════════════════════════════╗")
    println("║  Phase 2 에이전트 하네스 — 오케스트레이터 ║")
    println("╚═══════════════════════════════════════════╝")
    println("")

    ;; 에이전트 설정 생성
    println("1️⃣ 에이전트 설정")
    var sql_opt = agent_config_new("SQL-Optimizer", "dev", "claude-opus-4-6")
    sql_opt = agent_config_add_tools(sql_opt, ["query-analyzer", "index-suggester"])
    sql_opt = agent_config_set_timeout(sql_opt, 60000)
    println(agent_config_display(sql_opt))
    println("")

    ;; 레지스트리 생성 및 추가
    println("2️⃣ 에이전트 레지스트리")
    var registry = agent_registry_new()
    registry = registry_add(registry, sql_opt)

    var sec_scan = agent_config_new("Security-Scanner", "dev", "claude-opus-4-6")
    sec_scan = agent_config_add_tools(sec_scan, ["sast", "sca"])
    registry = registry_add(registry, sec_scan)

    println(registry_display(registry))
    println("등록된 에이전트:")
    var agents = registry_list(registry)
    var i: i32 = 0
    while i < length(agents) {
        println("  - " + agents[i])
        i = i + 1
    }
    println("")

    ;; 단일 에이전트 실행
    println("3️⃣ 단일 에이전트 실행")
    var run = harness_run(sql_opt, "SELECT * FROM users WHERE id = 1 (SLOW)")
    println(agent_run_display(run))
    println("")

    ;; 배치 실행
    println("4️⃣ 배치 실행")
    var configs: [AgentConfig] = [sql_opt]
    var inputs: [str] = ["Query 1", "Query 2"]
    var batch_result = harness_run_batch(configs, inputs)
    println(harness_result_display(batch_result))
    println("")

    ;; 성과 증명
    println("5️⃣ 성과 증명 생성")
    var proof = proof_output(run)
    println(substring(proof, 0, 150) + "...")
    println("")

    println("✅ 오케스트레이터 로드 완료")
}
